```html
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>反向攻略状态栏 (v11 - 代词修正)</title>
<style>
    /* 整体页面样式, 实现无边距效果 */
    body {
        margin: 0;
        padding: 0; /* 外边距和内边距都为0 */
        background-color: #f0f2f5; /* 背景色保留，方便预览 */
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        box-sizing: border-box;
    }

    /* 总容器, 去掉所有圆角、边框和阴影 */
    .widget-wrapper {
        width: 100%; /* 宽度占满父容器 */
        background-color: #ffffff;
        border-radius: 0; /* 修建方形角边 */
        border: none;
        box-shadow: none;
        overflow: hidden; /* 强制裁剪溢出的内容 */
    }

    /* 播放器主容器, 内边距保留以维持内部布局 */
    .player-container {
        padding: 15px 20px;
        box-sizing: border-box;
        position: relative;
    }

    /* 当面板展开时，主容器增加下边框分割线 */
    .widget-wrapper.expanded .player-container {
        border-bottom: 1px solid #f0f0f0;
    }

    /* -- 主状态栏内部样式 -- */
    .top-section { display: flex; align-items: center; margin-bottom: 15px; }
    .image-container { width: 70px; height: 70px; flex-shrink: 0; margin-right: 15px; border-radius: 8px; overflow: hidden; background-color: #f0f0f0; }
    .image-container img { width: 100%; height: 100%; object-fit: cover; }
    .user-input-section { width: 100%; display: flex; flex-direction: column; justify-content: space-around; height: 70px; }
    .live-indicator { font-size: 16px; color: #333; font-weight: 500; }
    .editable-input { width: 100%; padding: 4px 2px; border: none; border-bottom: 1px solid #ccc; box-sizing: border-box; font-size: 14px; color: #555; background: transparent; outline: none; cursor: text; }
    .editable-input:focus { border-bottom: 2px solid #000000; }
    .editable-input:empty:before {
        content: "想对他想说的话..."; /* 已将“她”修改为“他” */
        color: #aaa;
    }
    .progress-section { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
    .progress-bar { -webkit-appearance: none; appearance: none; width: 100%; height: 8px; background: #e9e9e9; border-radius: 4px; outline: none; cursor: pointer; }
    .progress-bar::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 14px; height: 14px; background: #000000; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 4px rgba(0,0,0,0.3); }
    .progress-bar::-moz-range-thumb { width: 14px; height: 14px; background: #000000; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 4px rgba(0,0,0,0.3); cursor: pointer; }
    .love-value { font-size: 14px; font-weight: 600; color: #555; min-width: 40px; text-align: right; }
    .stars-section { display: flex; justify-content: center; align-items: center; margin-bottom: 10px; font-size: 16px; color: #888; white-space: nowrap; overflow: hidden; }
    .volume-symbol { font-size: 12px; }
    #starsContainer { display: flex; padding: 0 5px; }
    .star-wrapper { position: relative; width: 16px; height: 16px; }
    .star-wrapper .star-bg, .star-wrapper .star-fg { position: absolute; top: 0; left: 0; white-space: nowrap; overflow: hidden; }
    .star-wrapper .star-bg { color: #e0e0e0; }
    .star-wrapper .star-fg { width: 0%; color: #000000; }
    .connector-line { flex-grow: 1; height: 1px; background-color: #ccc; }
    .player-controls { display: flex; justify-content: center; align-items: center; }
    .player-controls button { background: none; border: none; font-size: 24px; cursor: pointer; color: #555; transition: color 0.2s, transform 0.2s; padding: 0; display: flex; align-items: center; justify-content: center; height: 32px; width: 32px;}
    .player-controls button#prevBtn, .player-controls button#nextBtn { width: 40px; }
    .player-controls button:hover { color: #000; }
    .player-controls button:active { transform: scale(0.95); }
    .play-button { font-size: 28px !important; line-height: 1; }

    /* CSS绘制的暂停图标 */
    .pause-icon { width: 14px; height: 14px; display: flex; justify-content: space-between; }
    .pause-icon::before, .pause-icon::after { content: ''; display: block; width: 3px; height: 14px; background-color: currentColor; border-radius: 1px; }

    /* 可展开面板的样式 */
    #extended-panel {
        display: none; max-height: 0; overflow: hidden; padding: 0 20px;
        color: #4D4D4D;
        background-image: url('https://iili.io/BWAEGtI.jpg'); background-size: cover; background-position: center;
        position: relative;
        transition: max-height 0.4s ease-in-out, padding 0.4s ease-in-out;
    }
    #extended-panel.show { padding: 20px; }
    #extended-panel::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255, 255, 255, 0.88); z-index: -1; }
    .panel-content { display: flex; flex-direction: column; gap: 15px; }
    .time-weather { display: flex; justify-content: space-between; font-size: 13px; }
.divider { height: 1px; background-color: #e0e0e0; margin: -5px 0; }
    .info-block { font-size: 14px; }
    .info-block .title { font-size: 12px; margin-bottom: 4px; font-weight: 600; }
    .clothing-block { background-color: rgba(255, 255, 255, 0.5); padding: 10px; border-radius: 8px; border: 1px solid #eee; }
    .mood-block { font-style: italic; }

</style>
</head>
<body>

<div class="widget-wrapper" id="widgetWrapper">
    <div class="player-container">
        <div class="top-section"><div class="image-container"><img id="charImage" src="https://iili.io/BWA5JSI.jpg" alt="角色图片"></div><div class="user-input-section"><div class="live-indicator">「ʟɪᴠᴇ: 🌨️」</div><div id="userInput" class="editable-input" contenteditable="true"></div></div></div>
        <div class="progress-section"><input type="range" id="loveSlider" class="progress-bar" min="0" max="100" value="0"><span id="loveValue" class="love-value">0%</span></div>
        <div class="stars-section"><span class="volume-symbol">𖦤•ılıılııııı||ı|ııı||ı|</span><div class="connector-line"></div><div id="starsContainer"></div><div class="connector-line"></div><span class="volume-symbol">|ııı||ı|ııı||ıılıılıı. ⋆.˚ 𝄞⨾𓍢ִ໋ ♪</span></div>
        <div class="player-controls"><button id="prevBtn">«</button><button id="playBtn" class="play-button">►</button><button id="nextBtn">»</button></div>
    </div>

    <div id="extended-panel">
        <div class="panel-content">
            <div class="time-weather"><span id="datetime">...</span><span id="weather">天气：...</span></div>
            <div class="divider"></div>
            <div class="info-block clothing-block"><div class="title">❦ 角色服装：</div><div id="char-clothing">...</div></div>
            <div class="info-block clothing-block"><div class="title">❦ 你的服装：</div><div id="user-clothing">...</div></div>
            <div class="info-block"><strong>动作：</strong><span id="action">...</span></div>
            <div class="info-block"><strong>地点：</strong><span id="location">...</span></div>
            <div class="divider"></div>
            <div class="info-block mood-block"><div class="title">❦ 角色心情/想说的话：</div><div id="char-mood">"..."</div></div>
        </div>
    </div>
</div>

<script>
    const slider = document.getElementById('loveSlider');
    const valueDisplay = document.getElementById('loveValue');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const starsContainer = document.getElementById('starsContainer');
    const charImage = document.getElementById('charImage');
    const playBtn = document.getElementById('playBtn');
    const extendedPanel = document.getElementById('extended-panel');
    const widgetWrapper = document.getElementById('widgetWrapper');
    const datetimeDisplay = document.getElementById('datetime');

    const totalStars = 5;
    const imageUrls = ['https://iili.io/BWA5JSI.jpg', 'https://iili.io/BWA5HcN.jpg', 'https://iili.io/BWARpPR.jpg', 'https://iili.io/BWAORbs.jpg', 'https://iili.io/BWA59Fp.jpg', 'https://iili.io/BWA5Kts.jpg'];

    for (let i = 0; i < totalStars; i++) {
        const starWrapper = document.createElement('div'); starWrapper.className = 'star-wrapper';
        const starBg = document.createElement('span'); starBg.className = 'star-bg'; starBg.textContent = '★';
        const starFg = document.createElement('span'); starFg.className = 'star-fg'; starFg.textContent = '★';
        starWrapper.appendChild(starBg); starWrapper.appendChild(starFg);
        starsContainer.appendChild(starWrapper);
    }
    const starForegrounds = document.querySelectorAll('.star-fg');

    function updateUI(value) {
        slider.value = value;
        valueDisplay.textContent = `${value}%`;
        slider.style.background = `linear-gradient(to right, #000000 ${value}%, #e9e9e9 ${value}%)`;
        const filledStars = value / 20;
        starForegrounds.forEach((star, index) => {
            if (index < Math.floor(filledStars)) star.style.width = '100%';
            else if (index === Math.floor(filledStars)) star.style.width = `${(filledStars - Math.floor(filledStars)) * 100}%`;
            else star.style.width = '0%';
        });
        let imageIndex = Math.min(5, Math.floor(value / 20));
        if (value === 100) imageIndex = 5;
        if (charImage.src !== imageUrls[imageIndex]) charImage.src = imageUrls[imageIndex];
    }

    slider.addEventListener('input', () => updateUI(parseInt(slider.value)));
    prevBtn.addEventListener('click', () => { let val = parseInt(slider.value); if (val > 0) updateUI(--val); });
    nextBtn.addEventListener('click', () => { let val = parseInt(slider.value); if (val < 100) updateUI(++val); });

    playBtn.addEventListener('click', () => {
        const isExpanded = widgetWrapper.classList.contains('expanded');
        if (isExpanded) {
            extendedPanel.style.maxHeight = '0';
            extendedPanel.classList.remove('show');
            playBtn.innerHTML = '►';
widgetWrapper.classList.remove('expanded');
        } else {
            extendedPanel.style.display = 'block';
            const panelHeight = extendedPanel.scrollHeight + 40;
            extendedPanel.style.maxHeight = panelHeight + 'px';
            extendedPanel.classList.add('show');
            playBtn.innerHTML = '<div class="pause-icon"></div>';
            widgetWrapper.classList.add('expanded');
            updateTime();
        }
    });

    function updateTime() {
        const now = new Date();
        const year = now.getFullYear(); const month = (now.getMonth() + 1).toString().padStart(2, '0');
        const day = now.getDate().toString().padStart(2, '0');
        const week = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'][now.getDay()];
        const hours = now.getHours().toString().padStart(2, '0'); const minutes = now.getMinutes().toString().padStart(2, '0');
        datetimeDisplay.textContent = `${year}年${month}月${day}日 ${week} ${hours}:${minutes}`;
    }

    updateUI(0);
</script>

</body>
</html>
